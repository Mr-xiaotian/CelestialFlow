{
    "global": {
        "theme": "light",
        "autoRefreshEnabled": true,
        "refreshInterval": 2000,
        "language": "zh-CN"
    },
    "dashboard": {
        "historyLimit": 100,
        "showStructureEdgeDelta": false,
        "useTotalPendingInStatus": false,
        "layout": {
            "left": [
                "mermaid",
                "analysis"
            ],
            "middle": [
                "status"
            ],
            "right": [
                "progress",
                "summary"
            ]
        }
    },
    "errors": {
        "pageSize": 20,
        "sortOrder": "newest"
    },
    "injection": {
        "showInjectableOnly": true
    }
}
